# ===== REQUIRED =====
JWT_SECRET=change_this_to_a_long_random_secret

# ===== EMAIL (required for account verification) =====
# SMTP host — examples: smtp.gmail.com, smtp.office365.com, smtp.sendgrid.net
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Set to true only if using port 465 (SSL). Leave false for port 587 (TLS/STARTTLS).
EMAIL_SECURE=false
# Your email address (used to authenticate with the SMTP server)
EMAIL_USER=you@gmail.com
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# For other providers: your normal password or API key
EMAIL_PASS=your_app_password_here
# The "From" name/address shown in the verification email
EMAIL_FROM=noreply@5stack.gg

# ===== APP =====
# Public URL of your server — used to build the verification link in the email
APP_URL=http://localhost:3000
PORT=3000
